APP_ENV=development
APP_NAME="Shaytan Machine"
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
APP_RELEASE=
DATABASE_URL=postgresql+psycopg://magamax:magamax@localhost:15432/shaytan_machine
REDIS_URL=redis://localhost:16379/0
DUCKDB_PATH=./data/analytics/shaytan_machine.duckdb
PARQUET_ROOT=./data/analytics/parquet
OBJECT_STORAGE_MODE=local
LOCAL_OBJECT_STORAGE_ROOT=./data/object-storage
EXPORT_ROOT=./data/exports
EXPORT_ASYNC_ENABLED=true
EXPORT_ASYNC_ROW_THRESHOLD=500
S3_ENDPOINT_URL=http://localhost:19000
S3_BUCKET=shaytan-machine
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
JWT_SECRET=change-me-for-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480
ASSISTANT_PROVIDER=deterministic
ASSISTANT_LLM_ENABLED=false
ASSISTANT_OPENAI_BASE_URL=https://api.openai.com/v1
ASSISTANT_OPENAI_API_KEY=
ASSISTANT_OPENAI_MODEL=gpt-5.4-mini
ASSISTANT_INPUT_USD_PER_1M_TOKENS=0.15
ASSISTANT_OUTPUT_USD_PER_1M_TOKENS=0.60
ASSISTANT_RUB_PER_USD=300
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
OTEL_ENABLED=false
OTEL_SERVICE_NAME=shaytan-machine-api
OTEL_EXPORTER_OTLP_ENDPOINT=
STARTUP_SCHEMA_MODE=auto_create
STARTUP_SEED_SAMPLE_DATA=false
STARTUP_MATERIALIZE_ANALYTICS=false
DEV_ADMIN_EMAIL=admin@magamax.local
DEV_ADMIN_PASSWORD=magamax-admin
CORS_ORIGINS=http://127.0.0.1:8090,http://localhost:8090
