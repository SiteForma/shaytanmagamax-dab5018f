{
  "name": "shaytan-machine",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "install:web": "npm --prefix apps/web install",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "test:web": "npm --prefix apps/web run test",
    "lint:web": "npm --prefix apps/web run lint",
    "dev:api": "./.venv/bin/uvicorn apps.api.app.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:worker": "./.venv/bin/python -m apps.worker.worker_app.main",
    "test:api": "./.venv/bin/pytest",
    "lint:api": "./.venv/bin/ruff check . && ./.venv/bin/black --check . && ./.venv/bin/mypy apps/api"
  }
}
